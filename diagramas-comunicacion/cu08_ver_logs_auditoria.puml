@startuml
' ==============================================================
' CU08 - Ver Logs de Auditoría
' Administrador o Auditor revisa la trazabilidad de acciones
' ==============================================================
title CU08 - Ver Logs de Auditoría

skinparam objectBorderColor #005A9C
skinparam objectBackgroundColor #EBF2FF
skinparam objectFontName Arial
skinparam objectFontSize 11
skinparam noteBorderColor #AAAAAA
skinparam noteBackgroundColor #FFFFF0

' ── Participantes ─────────────────────────────────────────────
object "Admin / Auditor\n<<actor>>" as USR

object "<<boundary>>\nAuditLogsPage\n(React)" as UI

object "<<control>>\n:AuditController\nGET /audit/logs" as CTRL

object "<<control>>\n:RolesGuard\n(ADMIN | AUDITOR)" as GUARD

object "<<control>>\n:AuditService" as ASVC

object "<<entity>>\n:DatabaseService\n(pg Pool)" as DB

object "<<entity>>\nPostgreSQL\nrecibos_voto + usuarios\n+ elecciones + candidatos" as PG

' ── Flujo principal ───────────────────────────────────────────
USR -- UI : 1: navegarAuditoria()\n[filtros opcionales: electionId, estado]

UI -- CTRL : 2: GET /audit/logs\n[?electionId=&estado=]\n+ JWT Header

CTRL -- GUARD : 3: validateJWT() + checkRole(ADMIN | AUDITOR)
GUARD -- CTRL : 3.1: authorized

CTRL -- ASVC : 4: getLogs(filtros)

' Consulta enriquecida con JOINs para trazabilidad completa
ASVC -- DB : 5: query("SELECT\n  rv.id, rv.tx_id, rv.voto_id,\n  rv.estado, rv.created_at,\n  u.identificador, u.nombre AS votante,\n  e.titulo AS eleccion,\n  c.nombre_candidato\nFROM recibos_voto rv\nJOIN usuarios u    ON rv.id_usuario  = u.id\nJOIN elecciones e  ON rv.id_eleccion = e.id\nLEFT JOIN candidatos c ON rv.id_candidato = c.id\n[WHERE rv.id_eleccion=? AND rv.estado=?]\nORDER BY rv.created_at DESC")

DB -- PG : 6: executeSQL()
PG -- DB : 7: logs[]

DB -- ASVC : 8: AuditLog[]
ASVC -- CTRL : 9: AuditLog[]
CTRL -- UI : 10: 200 OK + logs JSON
UI -- USR : 11: tabla de trazabilidad:\nvotante | elección | candidato\ntxId | estado | fecha

note bottom of ASVC
  Campos de recibos_voto disponibles para auditoría:
    id_eleccion   → FK a elecciones
    id_usuario    → FK a usuarios
    id_candidato  → FK a candidatos
    tx_id         → hash de transacción Fabric
    voto_id       → UUID anónimo del voto en ledger
    estado        → CONFIRMADO | FALLIDO | PENDIENTE
    created_at    → timestamp de registro

  Rol AUDITOR tiene acceso de solo lectura.
  Rol ADMIN puede también ver todos los logs.
  Página frontend: AuditLogs.tsx en /admin/auditoria
end note

@enduml
