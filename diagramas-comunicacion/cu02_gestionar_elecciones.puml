@startuml
' ==============================================================
' CU02 - Gestionar Elecciones
' Administrador crea, edita y elimina elecciones
' ==============================================================
title CU02 - Gestionar Elecciones

skinparam objectBorderColor #005A9C
skinparam objectBackgroundColor #EBF2FF
skinparam objectFontName Arial
skinparam objectFontSize 11
skinparam noteBorderColor #AAAAAA
skinparam noteBackgroundColor #FFFFF0

' ── Participantes ─────────────────────────────────────────────
object "Administrador\n<<actor>>" as ADM

object "<<boundary>>\nElectionManagerPage\n(React)" as UI

object "<<control>>\n:ElectionController\n/elections" as CTRL

object "<<control>>\n:RolesGuard\n(ADMIN)" as GUARD

object "<<control>>\n:ElectionService" as SVC

object "<<entity>>\n:DatabaseService\n(pg Pool)" as DB

object "<<entity>>\nPostgreSQL\ntabla: elecciones" as PG

' ── Flujo principal: Crear elección ───────────────────────────
ADM -- UI : 1: submitNuevaEleccion(titulo,\nfechaInicio, fechaFin, descripcion)

UI -- CTRL : 2: POST /elections\n{titulo, descripcion,\nfecha_inicio, fecha_fin}

CTRL -- GUARD : 3: validateJWT() + checkRole(ADMIN)
GUARD -- CTRL : 3.1: authorized

CTRL -- SVC : 4: create(createElectionDto)

' Estado inicial siempre PROGRAMADA
SVC -- DB : 5: query("INSERT INTO elecciones\n(id_organizacion, titulo, descripcion,\nfecha_inicio, fecha_fin, estado)\nVALUES (..., 'PROGRAMADA')")
DB -- PG : 6: executeSQL()
PG -- DB : 7: {id, titulo, estado:'PROGRAMADA'}

DB -- SVC : 8: Election entity
SVC -- CTRL : 9: Election
CTRL -- UI : 10: 201 Created + Election JSON
UI -- ADM : 11: elección visible con\nestado PROGRAMADA

' ── Flujo alternativo: Listar elecciones ──────────────────────
ADM -- UI : 12: navegarListaElecciones()
UI -- CTRL : 13: GET /elections
CTRL -- SVC : 14: findAll()
SVC -- DB : 15: query("SELECT e.*, array_agg(c.*)\nFROM elecciones e\nLEFT JOIN candidatos c ON c.id_eleccion=e.id\nGROUP BY e.id\nORDER BY e.created_at DESC")
DB -- PG : 16: executeSQL()
PG -- DB : 17: [Election + candidatos[]]
DB -- SVC : 18: Election[]
SVC -- CTRL : 19: Election[]
CTRL -- UI : 20: 200 OK + Election[] JSON
UI -- ADM : 21: lista de elecciones con candidatos

note bottom of SVC
  Estado inicial al crear: PROGRAMADA (nunca BORRADOR)
  DELETE /elections/:id solo permitido si estado = PROGRAMADA
  PATCH /elections/:id → update titulo/descripcion/fechas
  Transiciones de estado → CU04 (ruta separada PATCH /status)
end note

@enduml
