@startuml
' ==============================================================
' CU07 - Ver Resultados Electorales
' Admin / Auditor / Público consulta resultados de una elección
' ==============================================================
title CU07 - Ver Resultados Electorales

skinparam objectBorderColor #005A9C
skinparam objectBackgroundColor #EBF2FF
skinparam objectFontName Arial
skinparam objectFontSize 11
skinparam noteBorderColor #AAAAAA
skinparam noteBackgroundColor #FFFFF0

' ── Participantes ─────────────────────────────────────────────
object "Actor\n(Admin / Auditor / Público)\n<<actor>>" as USR

object "<<boundary>>\nLiveResultsPage\nAdminResultsPage\nAuditorDashboard\n(React)" as UI

object "<<control>>\n:FabricController\nGET /fabric/results/:electionId" as CTRL

object "<<control>>\n:FabricService" as FSVC

object "<<entity>>\n:DatabaseService\n(pg Pool)" as DB

object "<<entity>>\nPostgreSQL\ncandidatos + recibos_voto" as PG

' ── Flujo principal ───────────────────────────────────────────
USR -- UI : 1: seleccionarEleccion(electionId)

' Ruta pública: no requiere JWT
UI -- CTRL : 2: GET /fabric/results/:electionId

CTRL -- FSVC : 3: obtenerResultados(electionId)

' Consulta desde PostgreSQL (no desde ledger Fabric directamente)
FSVC -- DB : 4: query("SELECT\n  c.id, c.nombre_frente,\n  c.nombre_candidato, c.nombre_cargo,\n  c.url_foto,\n  COUNT(r.id) AS votos\nFROM candidatos c\nLEFT JOIN recibos_voto r\n  ON r.id_candidato = c.id\n  AND r.estado = 'CONFIRMADO'\nWHERE c.id_eleccion = ?\nGROUP BY c.id\nORDER BY votos DESC")

DB -- PG : 5: executeSQL()
PG -- DB : 6: [{candidato, votos}]

DB -- FSVC : 7: resultados[]
FSVC -- CTRL : 8: ResultadosDto[]
CTRL -- UI : 9: 200 OK + resultados JSON
UI -- USR : 10: gráfico/tabla por candidato\ncon votos y porcentaje

note bottom of CTRL
  Ruta pública: GET /fabric/results/:electionId (sin JWT)
  Los resultados se leen desde PostgreSQL, NO directamente
  del ledger de Fabric → disponible aunque Fabric esté offline.

  Los recibos_voto con estado='CONFIRMADO' son la fuente
  de verdad para el conteo (sincronizados desde Fabric).

  Páginas que consumen esta ruta:
    /elecciones          → LiveResults.tsx   (público)
    /admin/resultados    → AdminResults.tsx  (admin)
    /auditor/resultados  → AuditorDashboard  (auditor)
end note

@enduml
