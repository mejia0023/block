@startuml
' ==============================================================
' CU09 - Gestionar Nodos Fabric
' Administrador añade, quita y monitorea peers de Fabric
' ==============================================================
title CU09 - Gestionar Nodos Fabric

skinparam objectBorderColor #005A9C
skinparam objectBackgroundColor #EBF2FF
skinparam objectFontName Arial
skinparam objectFontSize 11
skinparam noteBorderColor #AAAAAA
skinparam noteBackgroundColor #FFFFF0

' ── Participantes ─────────────────────────────────────────────
object "Administrador\n<<actor>>" as ADM

object "<<boundary>>\nNodesPage\n(React)" as UI

object "<<control>>\n:NodeController\n/nodes" as CTRL

object "<<control>>\n:RolesGuard\n(ADMIN)" as GUARD

object "<<control>>\n:NodeService" as NSVC

object "<<entity>>\n:DatabaseService\n(pg Pool)" as DB

object "<<entity>>\nPostgreSQL\ntabla: nodos_fabric" as PG

object "<<control>>\nWSL Shell\n(child_process.exec)" as WSL

object "<<entity>>\nDocker Daemon\n(dentro de WSL)" as DOCKER

object "<<entity>>\nFabricPeer\n(nuevo nodo)" as PEER

' ── Flujo A: Registrar nodo ───────────────────────────────────
ADM -- UI : 1: registrarNodo(endpoint, host_alias, prioridad)
UI -- CTRL : 2: POST /nodes\n{endpoint, host_alias, prioridad}
CTRL -- GUARD : 3: validateJWT() + checkRole(ADMIN)
GUARD -- CTRL : 3.1: authorized
CTRL -- NSVC : 4: createNode(nodeDto)
NSVC -- DB : 5: query("INSERT INTO nodos_fabric\n(endpoint, host_alias, activo, prioridad)\nVALUES (...)")
DB -- PG : 6: executeSQL()
PG -- DB : 7: nodo registrado
DB -- NSVC : 8: Node entity
NSVC -- CTRL : 9: Node
CTRL -- UI : 10: 201 Created + Node JSON
UI -- ADM : 11: nodo visible en lista

' ── Flujo B: Toggle start/stop ────────────────────────────────
ADM -- UI : 12: clickToggleNodo(nodeId)
UI -- CTRL : 13: POST /nodes/:id/toggle
CTRL -- GUARD : 14: validateJWT() + checkRole(ADMIN)
GUARD -- CTRL : 14.1: authorized
CTRL -- NSVC : 15: toggleNode(nodeId)
NSVC -- DB : 16: query("SELECT activo, endpoint\nFROM nodos_fabric WHERE id=?")
DB -- PG : 17: executeSQL()
PG -- DB : 18: {activo: false, endpoint: "peer1:8051"}
NSVC -- WSL : 19: exec("wsl bash -c\n'docker start peer1.ficct.edu.bo'")
WSL -- DOCKER : 20: docker start <container>
DOCKER -- WSL : 21: container started
WSL -- NSVC : 22: stdout: "peer1 started"
NSVC -- DB : 23: query("UPDATE nodos_fabric\nSET activo=true WHERE id=?")
DB -- PG : 24: executeSQL()
PG -- DB : 25: rowUpdated
NSVC -- CTRL : 26: {activo: true}
CTRL -- UI : 27: 200 OK {activo: true}
UI -- ADM : 28: nodo marcado como activo en UI

' ── Flujo C: Desplegar nuevo peer dinámico ────────────────────
ADM -- UI : 29: desplegarNuevoPeer(config)
UI -- CTRL : 30: POST /nodes/deploy {config}
CTRL -- NSVC : 31: deployPeer(config)
NSVC -- WSL : 32: exec("wsl bash\n'/mnt/c/.../add-peer-dynamic.sh'\n<orgName> <peerPort> <ccPort>")
WSL -- DOCKER : 33: docker run <peer_image>\ncon config de red Fabric
DOCKER -- PEER : 34: peer container running\n+ unido al canal
WSL -- NSVC : 35: script output (stdout)
NSVC -- CTRL : 36: deployResult
CTRL -- UI : 37: 200 OK + deployResult
UI -- ADM : 38: nuevo peer disponible en red

note bottom of NSVC
  FabricService.reconnect() consulta nodos_fabric al arrancar:
  → SELECT * FROM nodos_fabric WHERE activo=true ORDER BY prioridad ASC
  → elige el peer de mayor prioridad como endpoint activo
  → fallback a env vars si tabla no existe

  Rutas Windows a WSL: C:\... → /mnt/c/...
  child_process.exec() ejecuta comandos en WSL sin bloquear NestJS

  GET /nodes    → listar todos los nodos (activos e inactivos)
  DELETE /nodes/:id → eliminar registro del nodo
  Scripts en fabric/network/scripts/:
    add-peer-dynamic.sh → agrega peer extra a la red
end note

@enduml
