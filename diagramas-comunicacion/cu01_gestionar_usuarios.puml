@startuml
' ==============================================================
' CU01 - Gestionar Usuarios
' Administrador realiza CRUD de usuarios (votantes/admins/auditores)
' ==============================================================
title CU01 - Gestionar Usuarios

skinparam objectBorderColor #005A9C
skinparam objectBackgroundColor #EBF2FF
skinparam objectFontName Arial
skinparam objectFontSize 11
skinparam noteBorderColor #AAAAAA
skinparam noteBackgroundColor #FFFFF0

' ── Participantes ─────────────────────────────────────────────
object "Administrador\n<<actor>>" as ADM

object "<<boundary>>\nAdminUsersPage\n(React)" as UI

object "<<control>>\n:UserController\n/users" as CTRL

object "<<control>>\n:RolesGuard\n(ADMIN)" as GUARD

object "<<control>>\n:UserService" as SVC

object "<<entity>>\n:DatabaseService\n(pg Pool)" as DB

object "<<entity>>\nPostgreSQL\ntabla: usuarios" as PG

' ── Flujo principal: Crear usuario ────────────────────────────
ADM -- UI : 1: submitFormulario(datos)

' Frontend envía datos con JWT en el header Authorization
UI -- CTRL : 2: POST /users\n{identificador, nombre, rol,\nemail, password, carrera}

' Guard valida token y que el rol sea ADMIN
CTRL -- GUARD : 3: validateJWT() + checkRole(ADMIN)
GUARD -- CTRL : 3.1: authorized

' Controller delega en el servicio
CTRL -- SVC : 4: create(createUserDto)

' Servicio persiste (contraseña hasheada con bcrypt)
SVC -- DB : 5: query("INSERT INTO usuarios\n(id_organizacion, identificador,\nnombre, hash_contrasena, rol,\nmetadatos, habilitado)\nVALUES (...)")
DB -- PG : 6: executeSQL()
PG -- DB : 7: {id, identificador, nombre, rol}

' Resultado sube por la cadena
DB -- SVC : 8: User entity
SVC -- CTRL : 9: User
CTRL -- UI : 10: 201 Created + User JSON
UI -- ADM : 11: "Usuario creado exitosamente"

note bottom of CTRL
  Otras operaciones CRUD:
  GET  /users         → findAll()   → SELECT * FROM usuarios
                                       WHERE id_organizacion = ORG_ID
  PATCH /users/:id    → update()    → UPDATE usuarios SET ... WHERE id=?
  DELETE /users/:id   → remove()    → DELETE FROM usuarios WHERE id=?

  Restricciones DB:
  UNIQUE (id_organizacion, identificador)
  UNIQUE (id_organizacion, email)
  campo metadatos JSONB → {"carrera":"SISTEMAS"} para votantes
end note

@enduml
