@startuml
' ==============================================================
' CU03 - Gestionar Candidatos
' Administrador registra candidatos por elección
' ==============================================================
title CU03 - Gestionar Candidatos

skinparam objectBorderColor #005A9C
skinparam objectBackgroundColor #EBF2FF
skinparam objectFontName Arial
skinparam objectFontSize 11
skinparam noteBorderColor #AAAAAA
skinparam noteBackgroundColor #FFFFF0

' ── Participantes ─────────────────────────────────────────────
object "Administrador\n<<actor>>" as ADM

object "<<boundary>>\nElectionManagerPage\n(tab Candidatos)" as UI

object "<<control>>\n:ElectionController\n/elections/:id/candidates" as CTRL

object "<<control>>\n:RolesGuard\n(ADMIN)" as GUARD

object "<<control>>\n:ElectionService" as SVC

object "<<entity>>\n:DatabaseService\n(pg Pool)" as DB

object "<<entity>>\nPostgreSQL\nelecciones + candidatos" as PG

' ── Flujo principal: Agregar candidato ────────────────────────
ADM -- UI : 1: submitCandidato(nombre_frente,\nnombre_candidato, cargo, url_foto)

UI -- CTRL : 2: POST /elections/:id/candidates\n{nombre_frente, nombre_candidato,\nnombre_cargo, url_foto}

CTRL -- GUARD : 3: validateJWT() + checkRole(ADMIN)
GUARD -- CTRL : 3.1: authorized

CTRL -- SVC : 4: addCandidate(electionId, candidateDto)

' Verificar que la elección esté en PROGRAMADA
SVC -- DB : 5: query("SELECT estado FROM elecciones\nWHERE id=? AND id_organizacion=?")
DB -- PG : 6: executeSQL()
PG -- DB : 7: {estado: 'PROGRAMADA'}
DB -- SVC : 8: validación OK

' Insertar candidato
SVC -- DB : 9: query("INSERT INTO candidatos\n(id_eleccion, nombre_frente,\nnombre_candidato, nombre_cargo,\nurl_foto)\nVALUES (...)")
DB -- PG : 10: executeSQL()
PG -- DB : 11: {id, nombre_frente, nombre_candidato}

DB -- SVC : 12: Candidate entity
SVC -- CTRL : 13: Candidate
CTRL -- UI : 14: 201 Created + Candidate JSON
UI -- ADM : 15: candidato visible en lista

' ── Flujo alternativo: Listar candidatos ─────────────────────
ADM -- UI : 16: verCandidatos(electionId)
UI -- CTRL : 17: GET /elections/:id/candidates
CTRL -- SVC : 18: getCandidates(electionId)
SVC -- DB : 19: query("SELECT * FROM candidatos\nWHERE id_eleccion=?\nORDER BY created_at ASC")
DB -- PG : 20: executeSQL()
PG -- DB : 21: candidatos[]
DB -- SVC : 22: Candidate[]
SVC -- CTRL : 23: Candidate[]
CTRL -- UI : 24: 200 OK + Candidate[] JSON
UI -- ADM : 25: lista de candidatos con fotos

note bottom of SVC
  Solo se pueden agregar/eliminar candidatos
  si elección está en estado PROGRAMADA.
  Si estado != PROGRAMADA → 400 Bad Request.

  DELETE /elections/:electionId/candidates/:id
    → DELETE FROM candidatos WHERE id=? AND id_eleccion=?
  TypeScript mapping:
    candidate.frontName    → candidatos.nombre_frente
    candidate.candidateName → candidatos.nombre_candidato
    candidate.position     → candidatos.nombre_cargo
    candidate.photoUrl     → candidatos.url_foto
end note

@enduml
